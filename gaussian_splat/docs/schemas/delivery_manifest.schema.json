{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://3wa.tw/schemas/photogrammetry-studio/delivery_manifest.schema.json",
  "title": "Photogrammetry Studio Delivery Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "mode", "status", "generated_at", "delivery_tracks"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "studio_job_id": {
      "type": ["integer", "null"]
    },
    "status": {
      "type": "string",
      "enum": ["ready", "review_needed", "not_ready"]
    },
    "generated_at": {
      "type": "string"
    },
    "delivery_tracks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/delivery_track"
      }
    },
    "qa_report_path": {
      "type": ["string", "null"]
    },
    "version": {
      "type": "string"
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["fast", "qa", "premium"]
    },
    "primary_artifact": {
      "anyOf": [
        {
          "$ref": "#/$defs/artifact_ref"
        },
        {
          "type": "null"
        }
      ]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact_ref"
      }
    },
    "validation_report": {
      "type": "string"
    },
    "readiness": {
      "type": "string",
      "enum": ["ready", "review_needed", "not_ready"]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "delivery_track": {
      "type": "object",
      "required": ["track", "engine", "role", "delivery_capable", "primary_artifact"],
      "additionalProperties": true,
      "properties": {
        "track": {
          "type": "string",
          "enum": ["mesh", "splat"]
        },
        "engine": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["delivery_candidate", "diagnostic", "delivery_capable"]
        },
        "delivery_capable": {
          "type": "boolean"
        },
        "primary_artifact": {
          "$ref": "#/$defs/primary_artifact"
        },
        "preview_artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/primary_artifact"
          }
        },
        "contract_path": {
          "type": ["string", "null"]
        },
        "validation_report_path": {
          "type": ["string", "null"]
        }
      }
    },
    "primary_artifact": {
      "type": "object",
      "required": ["type", "path"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string"
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "artifact_ref": {
      "type": "object",
      "required": ["type", "path"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "engine": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["primary", "diagnostic", "fidelity", "supporting"]
        }
      }
    }
  }
}
