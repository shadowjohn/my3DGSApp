{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://3wa.tw/schemas/photogrammetry-studio/engine_contract.schema.json",
  "title": "Photogrammetry Studio Engine Contract",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "job_id", "mode", "status", "artifacts"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "engine_name": {
      "type": "string"
    },
    "engine_version": {
      "type": "string"
    },
    "pipeline_mode": {
      "type": "string",
      "enum": ["fast", "qa", "premium"]
    },
    "role": {
      "type": "string",
      "enum": ["primary", "delivery_candidate", "diagnostic", "delivery_capable", "fidelity", "supporting"]
    },
    "delivery_capable": {
      "type": "boolean"
    },
    "generated_at": {
      "type": "string"
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["fast", "qa", "premium"]
    },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "completed", "failed", "review_required"]
    },
    "coordinate_system": {
      "$ref": "#/$defs/coordinate_system"
    },
    "sources": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "sfm": {
          "$ref": "#/$defs/source"
        },
        "geometry": {
          "$ref": "#/$defs/source"
        },
        "appearance": {
          "$ref": "#/$defs/source"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": true
    },
    "validation_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "coordinate_system": {
      "type": "object",
      "required": ["base"],
      "additionalProperties": true,
      "properties": {
        "base": {
          "type": "string",
          "const": "colmap_world"
        },
        "unit": {
          "type": "string"
        },
        "up_axis": {
          "type": "string"
        },
        "viewer_transform": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "transforms": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "openmvs_to_colmap": {},
            "gaussian_to_colmap": {},
            "viewer_to_colmap": {}
          }
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["engine"],
      "additionalProperties": true,
      "properties": {
        "engine": {
          "type": "string",
          "minLength": 1
        },
        "workspace": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "artifact": {
      "type": "object",
      "required": ["type", "path"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "camera_poses",
            "coverage_summary",
            "dense_cloud",
            "engine_contract",
            "geometry_summary",
            "mesh",
            "splat",
            "texture",
            "validation_report"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string"
        },
        "engine": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["primary", "delivery_candidate", "diagnostic", "delivery_capable", "fidelity", "supporting"]
        },
        "delivery_capable": {
          "type": "boolean"
        }
      }
    }
  }
}
